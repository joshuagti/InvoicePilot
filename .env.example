# MySQL (Prisma)
# Local MySQL, or Docker: `docker compose up -d` then use localhost below.
DATABASE_URL="mysql://user:password@localhost:3306/invoice_pilot"
# App container on Docker Compose uses host `db` instead of localhost:
# DATABASE_URL="mysql://user:password@db:3306/invoice_pilot"

# Encrypt mailbox passwords and app-stored secrets (32-byte hex = 64 chars) — generate: openssl rand -hex 32
ENCRYPTION_KEY=""

# App auth (review/dashboard) — set a strong secret; login uses APP_PASSWORD
APP_PASSWORD="change-me-in-production"
SESSION_SECRET="generate-a-long-random-string"

# Optional: default model
OPENAI_MODEL="gpt-4o-mini"

# Optional: Bearer secret for POST /api/mail/poll from cron (no browser cookie)
CRON_SECRET=""
